<script>
// Current language
var currentLang = 'es';

function toggleLang() {
  var flagEl = document.getElementById('langFlag');
  var labelEl = document.getElementById('langLabel');
  if (currentLang === 'es') {
    currentLang = 'en';
    document.body.classList.remove('lang-es');
    document.body.classList.add('lang-en');
    // Now in EN → button shows 🇪🇸 ES to switch back to Spanish
    flagEl.textContent = '\uD83C\uDDEA\uD83C\uDDF8';
    labelEl.textContent = 'ES';
    document.documentElement.lang = 'en';
  } else {
    currentLang = 'es';
    document.body.classList.remove('lang-en');
    document.body.classList.add('lang-es');
    // Now in ES → button shows 🇬🇧 EN to switch to English
    flagEl.textContent = '\uD83C\uDDEC\uD83C\uDDE7';
    labelEl.textContent = 'EN';
    document.documentElement.lang = 'es';
  }
}

// Initialize language
document.body.classList.add('lang-es');

function showView(id, btn) {
  document.querySelectorAll('.view').forEach(function(v){ v.classList.remove('active'); });
  document.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
  var el = document.getElementById(id);
  if (el) el.classList.add('active');
  if (btn) btn.classList.add('active');
  window.scrollTo(0, 0);
}

function toggle(header) {
  var card = header.closest('.card');
  if (card) card.classList.toggle('open');
}

function toggleEx(header) {
  var card = header.closest('.ex-card');
  if (card) card.classList.toggle('open');
}

function filterEx(unit, btn) {
  document.querySelectorAll('.pu-btn').forEach(function(b){ b.classList.remove('active'); });
  if (btn) btn.classList.add('active');
  document.querySelectorAll('.ex-card').forEach(function(c){
    c.style.display = (unit === 'all' || c.dataset.unit === unit) ? '' : 'none';
  });
  document.querySelectorAll('.sec-title[data-unit]').forEach(function(t){
    t.style.display = (unit === 'all' || t.dataset.unit === unit) ? '' : 'none';
  });
}
// ── SEARCH ENGINE ────────────────────────────────────────
var MODULE_LABELS = {
  m1:'M1', m2:'M2', m3:'M3', m4:'M4', m5:'M5',
  m6:'M6', m7:'M7', ex:'EJ', qr:'QR', img:'IMG'
};
var MODULE_COLORS = {
  m1:'#1d4ed8', m2:'#15803d', m3:'#b45309', m4:'#b91c1c',
  m5:'#1d4ed8', m6:'#15803d', m7:'#b91c1c', ex:'#15803d',
  qr:'#7c3aed', img:'#0f766e'
};

// Build search index once DOM is ready
var searchIndex = [];
function buildIndex() {
  var views = document.querySelectorAll('.view');
  views.forEach(function(view) {
    var vid = view.id;
    // Get all text containers: cards, tables, alerts, kv, steps
    var blocks = view.querySelectorAll(
      '.card-header, .card-body, .ex-header, .ex-body, tr, .alert, .kv, .step-body, .scenario, .mod-header, .exam-tip, td, th, .sec-title'
    );
    blocks.forEach(function(block) {
      var raw = block.innerText || block.textContent || '';
      raw = raw.replace(/\s+/g,' ').trim();
      if (raw.length < 8) return;
      // Get nearest heading for title
      var title = '';
      var cardTitle = block.closest('.card, .ex-card');
      if (cardTitle) {
        var h = cardTitle.querySelector('.card-title, .ex-title');
        if (h) title = (h.innerText || h.textContent || '').replace(/\s+/g,' ').trim().slice(0,70);
      }
      if (!title) {
        title = raw.slice(0, 60);
      }
      searchIndex.push({ vid: vid, title: title, text: raw });
    });
  });
}

var lastQuery = '';
var selectedIdx = -1;
var currentResults = [];

function doSearch(q) {
  q = q.trim();
  var clearBtn = document.getElementById('searchClear');
  var countEl = document.getElementById('searchCount');
  var resEl = document.getElementById('searchResults');

  // Toggle clear button
  clearBtn.style.display = q.length > 0 ? 'block' : 'none';

  // Remove page highlights
  removeHighlights();

  if (q.length < 2) {
    resEl.style.display = 'none';
    countEl.textContent = '';
    lastQuery = '';
    currentResults = [];
    return;
  }

  lastQuery = q;
  var ql = q.toLowerCase();
  var words = ql.split(/\s+/).filter(function(w){ return w.length > 0; });

  // Score each index entry
  var scored = [];
  var seenVidTitle = {};
  searchIndex.forEach(function(entry) {
    var tl = entry.text.toLowerCase();
    var score = 0;
    var allMatch = words.every(function(w){ return tl.indexOf(w) !== -1; });
    if (!allMatch) return;
    words.forEach(function(w) {
      // Title match = higher score
      if (entry.title.toLowerCase().indexOf(w) !== -1) score += 10;
      // Count occurrences
      var count = 0, pos = 0;
      while ((pos = tl.indexOf(w, pos)) !== -1) { count++; pos++; }
      score += count;
    });
    var key = entry.vid + '::' + entry.title.slice(0,40);
    if (!seenVidTitle[key] || seenVidTitle[key].score < score) {
      seenVidTitle[key] = { score: score, entry: entry };
    }
  });

  // Sort by score desc
  currentResults = Object.values(seenVidTitle)
    .sort(function(a,b){ return b.score - a.score; })
    .slice(0, 12)
    .map(function(x){ return x.entry; });

  // Deduplicate by module if too many
  selectedIdx = -1;
  renderResults(words);
}

function renderResults(words) {
  var resEl = document.getElementById('searchResults');
  var countEl = document.getElementById('searchCount');

  if (currentResults.length === 0) {
    resEl.innerHTML = '<div class="sr-empty">&#128269; <span class="es">Sin resultados para &ldquo;' + escHtml(lastQuery) + '&rdquo;</span><span class="en">No results for &ldquo;' + escHtml(lastQuery) + '&rdquo;</span></div>';
    resEl.style.display = 'block';
    countEl.textContent = '0';
    return;
  }

  countEl.textContent = currentResults.length + (currentResults.length === 12 ? '+' : '');

  var html = '';
  currentResults.forEach(function(entry, i) {
    var modLabel = MODULE_LABELS[entry.vid] || entry.vid.toUpperCase();
    var modColor = MODULE_COLORS[entry.vid] || '#64748b';
    var snippet = getSnippet(entry.text, words, 90);
    html += '<div class="sr-item" data-idx="' + i + '" onclick="goResult(' + i + ')">'
      + '<div style="display:flex;align-items:center;gap:6px;margin-bottom:3px">'
      + '<span class="sr-mod" style="background:' + modColor + '">' + modLabel + '</span>'
      + '<span class="sr-title">' + highlightWords(escHtml(entry.title), words) + '</span>'
      + '</div>'
      + '<div class="sr-snippet">' + snippet + '</div>'
      + '</div>';
  });
  resEl.innerHTML = html;
  resEl.style.display = 'block';
}

function getSnippet(text, words, maxLen) {
  var tl = text.toLowerCase();
  var best = 0;
  words.forEach(function(w) {
    var pos = tl.indexOf(w);
    if (pos !== -1) best = pos;
  });
  var start = Math.max(0, best - 30);
  var snippet = (start > 0 ? '…' : '') + text.slice(start, start + maxLen) + (start + maxLen < text.length ? '…' : '');
  return highlightWords(escHtml(snippet), words);
}

function highlightWords(html, words) {
  words.forEach(function(w) {
    if (w.length < 2) return;
    var re = new RegExp('(' + escRe(w) + ')', 'gi');
    html = html.replace(re, '<mark>$1</mark>');
  });
  return html;
}

function goResult(idx) {
  if (idx < 0 || idx >= currentResults.length) return;
  var entry = currentResults[idx];

  // Switch to the right view
  var tabBtns = document.querySelectorAll('.tab-btn');
  tabBtns.forEach(function(b){ b.classList.remove('active'); });
  document.querySelectorAll('.view').forEach(function(v){ v.classList.remove('active'); });
  var targetView = document.getElementById(entry.vid);
  if (targetView) targetView.classList.add('active');
  // Activate correct tab button
  tabBtns.forEach(function(b) {
    if (b.getAttribute('onclick') && b.getAttribute('onclick').indexOf("'" + entry.vid + "'") !== -1) {
      b.classList.add('active');
    }
  });

  // Open card if collapsed
  var cards = document.querySelectorAll('#' + entry.vid + ' .card, #' + entry.vid + ' .ex-card');
  cards.forEach(function(card) {
    var raw = (card.innerText || card.textContent || '').toLowerCase();
    var words = lastQuery.toLowerCase().split(/\s+/);
    var match = words.every(function(w){ return raw.indexOf(w) !== -1; });
    if (match) card.classList.add('open');
  });

  // Highlight text in the view
  removeHighlights();
  highlightInView(entry.vid, lastQuery.split(/\s+/));

  // Close dropdown
  document.getElementById('searchResults').style.display = 'none';

  // Scroll to first highlight
  setTimeout(function() {
    var first = document.querySelector('#' + entry.vid + ' mark.hl');
    if (first) first.scrollIntoView({ behavior:'smooth', block:'center' });
    else window.scrollTo(0,0);
  }, 80);
}

function highlightInView(vid, words) {
  var view = document.getElementById(vid);
  if (!view) return;
  var walker = document.createTreeWalker(view, NodeFilter.SHOW_TEXT, null, false);
  var nodes = [];
  var node;
  while (node = walker.nextNode()) nodes.push(node);
  nodes.forEach(function(node) {
    var val = node.nodeValue;
    if (!val || val.trim().length < 2) return;
    var lval = val.toLowerCase();
    var needsMark = words.some(function(w){ return w.length > 1 && lval.indexOf(w.toLowerCase()) !== -1; });
    if (!needsMark) return;
    var frag = document.createDocumentFragment();
    var re = new RegExp('(' + words.map(escRe).join('|') + ')', 'gi');
    var parts = val.split(re);
    parts.forEach(function(part) {
      if (re.test(part)) {
        var mark = document.createElement('mark');
        mark.className = 'hl';
        mark.textContent = part;
        frag.appendChild(mark);
      } else {
        frag.appendChild(document.createTextNode(part));
      }
    });
    if (frag.childNodes.length > 0 && node.parentNode) {
      node.parentNode.replaceChild(frag, node);
    }
  });
}

function removeHighlights() {
  document.querySelectorAll('mark.hl').forEach(function(m) {
    var parent = m.parentNode;
    if (parent) {
      parent.replaceChild(document.createTextNode(m.textContent), m);
      parent.normalize();
    }
  });
}

function clearSearch() {
  var inp = document.getElementById('globalSearch');
  inp.value = '';
  document.getElementById('searchResults').style.display = 'none';
  document.getElementById('searchClear').style.display = 'none';
  document.getElementById('searchCount').textContent = '';
  removeHighlights();
  lastQuery = '';
  currentResults = [];
  inp.focus();
}

function searchKeyNav(e) {
  var resEl = document.getElementById('searchResults');
  if (resEl.style.display === 'none') return;
  var items = resEl.querySelectorAll('.sr-item');
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    selectedIdx = Math.min(selectedIdx + 1, items.length - 1);
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    selectedIdx = Math.max(selectedIdx - 1, -1);
  } else if (e.key === 'Enter') {
    e.preventDefault();
    if (selectedIdx >= 0) goResult(selectedIdx);
    else if (currentResults.length > 0) goResult(0);
    return;
  } else if (e.key === 'Escape') {
    resEl.style.display = 'none';
    return;
  } else { return; }
  items.forEach(function(it, i) {
    it.style.background = i === selectedIdx ? 'var(--blue-light)' : '';
  });
  if (selectedIdx >= 0 && items[selectedIdx]) {
    items[selectedIdx].scrollIntoView({ block:'nearest' });
  }
}

// Close dropdown when clicking outside
document.addEventListener('click', function(e) {
  if (!document.getElementById('searchWrap').contains(e.target)) {
    var resEl = document.getElementById('searchResults');
    if (resEl) resEl.style.display = 'none';
  }
});

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function escRe(s) {
  return s.replace(/[.*+?^${}()|[\]\\]/g,'\\$&');
}

// Build index after page loads
window.addEventListener('load', function(){ setTimeout(buildIndex, 200); });
