        <tr><td><span class="es">Intervalo 2</span><span class="en">Interval 2</span></td><td><span class="es">Publicaciones en per&iacute;odos normales del ejercicio en curso.</span><span class="en">Postings in normal periods of the current fiscal year.</span></td></tr>
        <tr><td><span class="es">Intervalo 3</span><span class="en">Interval 3</span></td><td><span class="es">Publicaciones de Controlling (CO) a FI.</span><span class="en">Controlling (CO) to FI postings.</span></td></tr>
